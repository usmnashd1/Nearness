---
import BaseLayout from './BaseLayout.astro';
import type { Post } from '../lib/posts';
import { formatDate, getReadingTime } from '../lib/posts';

interface Props { post: Post; }
const { post } = Astro.props;
const { title, subtitle, excerpt, date, category, language, direction, tags, mood, quote, cover } = post.data;
const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path.replace(/^\//, '')}`;
---
<BaseLayout title={title} description={excerpt || subtitle} language={language} direction={direction}>
  <article class:list={['post-page', `language-${language}`, `direction-${direction}`]}>
    <header class="post-header">
      <a class="back-link" href={href('/archive/')}>← Archive</a>
      <div class="post-kicker">
        <a href={href(`/category/${category}/`)}>{category}</a>
        {mood && <span>{mood}</span>}
      </div>
      <h1>{title}</h1>
      {subtitle && <p class="post-subtitle">{subtitle}</p>}
      <div class="post-byline">
        <time datetime={date.toISOString()}>{formatDate(date, language)}</time>
        <span>{getReadingTime(post)}</span>
      </div>
      {quote && <blockquote class="opening-quote">{quote}</blockquote>}
      {cover && <img class="post-cover" src={href(cover)} alt="" />}
    </header>
    <div class="prose"><slot /></div>
    <footer class="post-tags">
      {tags.map((tag) => <a href={href(`/tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>)}
    </footer>
  </article>
</BaseLayout>
