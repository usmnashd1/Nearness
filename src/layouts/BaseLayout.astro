---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  language?: string;
  direction?: 'ltr' | 'rtl' | 'mixed';
}
const {
  title = 'Nearness',
  description = 'A small archive for staying sane near the edge of thought.',
  language = 'en',
  direction = 'ltr',
} = Astro.props;
const pageTitle = title === 'Nearness' ? title : `${title} · Nearness`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang={language === 'mixed' ? 'en' : language} dir={direction === 'mixed' ? 'ltr' : direction} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b0f14" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Nastaliq+Urdu:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      document.documentElement.dataset.theme = localStorage.getItem('nearness-theme') || 'dark';
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main><slot /></main>
      <Footer />
    </div>
  </body>
</html>
