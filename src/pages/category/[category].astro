---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { sortPosts, unique } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts'));
  return unique(posts.map((post) => post.data.category)).map((category) => ({
    params: { category }, props: { posts: posts.filter((post) => post.data.category === category) },
  }));
}
const { category } = Astro.params;
const { posts } = Astro.props;
---
<BaseLayout title={category}>
  <header class="page-header"><p class="eyebrow">Category</p><h1>{category}</h1><p>{posts.length} {posts.length === 1 ? 'entry' : 'entries'} in this part of the archive.</p></header>
  <div class="post-feed">{posts.map((post) => <PostCard post={post} />)}</div>
</BaseLayout>
