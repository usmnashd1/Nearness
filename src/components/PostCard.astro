---
import type { Post } from '../lib/posts';
import { formatDate, getReadingTime, postPath } from '../lib/posts';

interface Props { post: Post; }
const { post } = Astro.props;
const { title, excerpt, subtitle, date, category, language, tags } = post.data;
const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path.replace(/^\//, '')}`;
---
<article class:list={['post-card', { 'is-urdu': language === 'ur' }]}>
  <div class="post-card-meta">
    <time datetime={date.toISOString()}>{formatDate(date, language)}</time>
    <span>{getReadingTime(post)}</span>
    <span>{language === 'ur' ? 'اردو' : language === 'mixed' ? 'EN / اردو' : 'EN'}</span>
  </div>
  <h2><a href={href(postPath(post.id))}>{title}</a></h2>
  <p>{excerpt || subtitle || 'A fragment from the archive.'}</p>
  <div class="post-card-footer">
    <a class="category" href={href(`/category/${category}/`)}>{category}</a>
    <div class="tag-list" aria-label="Tags">
      {tags.map((tag) => <a href={href(`/tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>)}
    </div>
  </div>
</article>
